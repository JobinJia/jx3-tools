{
  "name": "jx3-tools",
  "type": "module",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "description": "JX3 Tools - Desktop utilities for JX3 game",
  "author": "jobinJia",
  "license": "MIT",
  "keywords": [
    "vite",
    "vue3",
    "typescript"
  ],
  "engines": {
    "node": ">= 20.19.0"
  },
  "scripts": {
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "release": "bumpp"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "alova": "^3.5.1",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "shuimo-ui": "npm:shuimo-ui-nightly@0.3.0-alpha.14-nightly.20250606",
    "the-new-css-reset": "^1.11.3",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/fluent-emoji-flat": "^1.2.5",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.76",
    "@iconify-json/noto": "^1.2.7",
    "@iconify-json/noto-v1": "^1.2.5",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "@unocss/eslint-config": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-sfc": "^3.5.35",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.3.0",
    "bumpp": "^11.1.0",
    "cypress": "^15.17.0",
    "eslint": "^10.4.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "naive-ui": "^2.44.1",
    "npm-run-all": "^4.1.5",
    "start-server-and-test": "^3.0.9",
    "typescript": "~6.0.3",
    "unocss": "^66.7.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
